{
  "name": "dietclaw",
  "version": "0.2.0",
  "description": "Codebase health monitor. Find out why your project is getting fat.",
  "type": "module",
  "bin": {
    "dietclaw": "dist/cli.js"
  },
  "files": [
    "dist",
    "data",
    "assets"
  ],
  "scripts": {
    "cli": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome format --write",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "cli",
    "codebase",
    "health",
    "bloat",
    "dependencies",
    "openclaw"
  ],
  "author": "psandis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/psandis/dietclaw.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
